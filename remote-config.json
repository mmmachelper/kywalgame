{
  "version": 3,
  "remoteControl": {
    "appEnabled": true,
    "maintenance": {
      "enabled": false,
      "title": "Maintenance",
      "message": "Server upgrade in progress. Please try again later."
    },
    "update": {
      "enabled": true,
      "force": false,
      "minVersionCode": 2,
      "latestVersionName": "1.0.1",
      "title": "Update Available",
      "message": "A newer version is available.",
      "androidStoreUrl": "https://play.google.com/store/apps/details?id=com.buffalo.fungames",
      "fallbackUrl": "https://your-site.com/download"
    }
  },
  "app": {
    "name": "Kywal Game",
    "title": "KYWAL GAME",
    "subtitle": "Tap buttons below to contact or play"
  },
  "policy": {
    "enabled": true,
    "title": "Policy",
    "content": "Please play responsibly. By using this app, you agree to the platform terms and privacy policy.",
    "url": "https://your-site.com/policy"
  },
  "home": {
    "contactText": "အကောင့်ဖွင့်ရန်ဆက်သွယ်ပါ ဟုတ်ကဲ့",
    "logoAsset": "",
    "logoUrl": "https://raw.githubusercontent.com/mmmachelper/kywalgame/refs/heads/main/2.png",
    "policyIcon": {
      "enabled": true,
      "icon": "shield",
      "action": {
        "type": "route",
        "route": "policy"
      }
    },
    "background": {
      "type": "image",
      "imageUrl": "https://raw.githubusercontent.com/mmmachelper/kywalgame/refs/heads/main/2.png",
      "assetPath": "",
      "fit": "cover",
      "alignment": "center",
      "overlay": {
        "enabled": true,
        "type": "gradient",
        "colors": ["#22000000", "#66000000", "#99000000"],
        "begin": "topCenter",
        "end": "bottomCenter"
      }
    },
    "buttonStyle": {
      "backgroundColor": "#F97316",
      "textColor": "#FFFFFF",
      "iconColor": "#FFFFFF",
      "height": 56,
      "radius": 18,
      "spacing": 10
    },
    "buttons": [
      {
        "id": "play_game_1",
        "label": "Play Game",
        "icon": "sports_esports",
        "visible": true,
        "action": { "type": "route", "route": "game1_match3" }
      },
      {
        "id": "exit_game",
        "label": "Exit Game",
        "icon": "exit_to_app",
        "visible": true,
        "action": { "type": "exit" }
      },
      {
        "id": "contact_telegram",
        "label": "Telegram",
        "icon": "telegram",
        "visible": true,
        "action": {
          "type": "url",
          "url": "https://t.me/X109110",
          "fallbackUrl": ""
        }
      },
      {
        "id": "contact_viber",
        "label": "Viber",
        "icon": "phone_in_talk",
        "visible": true,
        "action": {
          "type": "url",
          "url": "viber://chat?number=%2B959123456789",
          "fallbackUrl": "https://www.viber.com/"
        }
      }
    ]
  },
  "games": {
    "game1_match3": { "enabled": true },
    "game2_slot": { "enabled": false },
    "game3_memory": { "enabled": false }
  }
}
