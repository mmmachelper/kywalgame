{
  "version": 2,
  "remoteControl": {
    "appEnabled": true,
    "maintenance": {
      "enabled": false,
      "title": "Maintenance",
      "message": "Server upgrade in progress. Please try again later."
    },
    "update": {
      "enabled": true,
      "force": false,
      "minVersionCode": 2,
      "latestVersionName": "1.0.1",
      "title": "Update Available",
      "message": "A newer version is available.",
      "androidStoreUrl": "https://play.google.com/store/apps/details?id=com.example.kywal_game",
      "fallbackUrl": "https://your-site.com/download"
    }
  },
  "app": {
    "name": "Kywal Game",
    "title": "KYWAL GAME",
    "subtitle": "Tap buttons below to contact or play"
  },
  "home": {
    "background": {
      "type": "image",
      "imageUrl": "https://your-cdn.com/backgrounds/cinematic_bg_01.jpg",
      "assetPath": "assets/backgrounds/cinematic_bg_01.jpg",
      "fit": "cover",
      "alignment": "center",
      "overlay": {
        "enabled": true,
        "type": "gradient",
        "colors": ["#66000000", "#99000000", "#CC000000"],
        "begin": "topCenter",
        "end": "bottomCenter"
      }
    },
    "panel": {
      "enabled": true,
      "color": "#1A120C",
      "borderColor": "#E07A0A",
      "borderWidth": 1.3,
      "radius": 28,
      "padding": 18,
      "shadow": {
        "enabled": true,
        "color": "#55000000",
        "blurRadius": 22,
        "offsetX": 0,
        "offsetY": 12
      }
    },
    "buttonStyle": {
      "backgroundColor": "#F89B2A",
      "textColor": "#301602",
      "iconColor": "#301602",
      "height": 54,
      "radius": 16,
      "spacing": 10
    },
    "buttons": [
      {
        "id": "contact_viber",
        "label": "Contact Viber",
        "icon": "phone_in_talk",
        "visible": true,
        "action": {
          "type": "url",
          "url": "viber://chat?number=%2B959123456789",
          "fallbackUrl": "https://www.viber.com/"
        }
      },
      {
        "id": "contact_telegram",
        "label": "Contact Telegram",
        "icon": "telegram",
        "visible": true,
        "action": {
          "type": "url",
          "url": "https://t.me/your_telegram_username"
        }
      },
      {
        "id": "play_game_1",
        "label": "Play Game",
        "icon": "sports_esports",
        "visible": true,
        "action": {
          "type": "route",
          "route": "game1_match3"
        }
      },
      {
        "id": "play_game_2",
        "label": "Play Game 2",
        "icon": "casino",
        "visible": true,
        "action": {
          "type": "route",
          "route": "game2_slot"
        }
      },
      {
        "id": "play_game_3",
        "label": "Play Game 3",
        "icon": "extension",
        "visible": true,
        "action": {
          "type": "route",
          "route": "game3_memory"
        }
      },
      {
        "id": "exit_game",
        "label": "Exit Game",
        "icon": "exit_to_app",
        "visible": true,
        "action": {
          "type": "exit"
        }
      }
    ]
  },
  "games": {
    "game1_match3": {
      "enabled": true,
      "title": "MATCH GAME",
      "timerSeconds": 80,
      "scorePerTile": 10,
      "trophyPerScore": 200,
      "animation": {
        "swapMs": 70,
        "resolveStepMs": 420,
        "fallBaseMs": 320,
        "fallPerStepMs": 80
      }
    },
    "game2_slot": {
      "enabled": true,
      "title": "SLOT GAME",
      "spinCount": 30,
      "rewards": {
        "threeSame": 120,
        "twoSame": 35,
        "noMatch": 5
      },
      "trophyPerScore": 200
    },
    "game3_memory": {
      "enabled": true,
      "title": "MEMORY FLIP",
      "timerSeconds": 80,
      "pairs": 6,
      "rewardMatch": 20,
      "penaltyMismatch": 3,
      "trophyPerScore": 150
    }
  },
  "assets": {
    "icons": [
      "assets/icons/icon_1.png",
      "assets/icons/icon_2.png",
      "assets/icons/icon_3.png",
      "assets/icons/icon_4.png",
      "assets/icons/icon_5.png",
      "assets/icons/icon_6.png"
    ],
    "fallbackBackgroundAsset": "assets/backgrounds/cinematic_bg_01.jpg"
  }
}
